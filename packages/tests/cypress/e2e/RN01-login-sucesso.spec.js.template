 * Regra de Negócio: RN01 - Login
 */

import { API_BASE_URL, WEB_BASE_URL, QA_PREFIX, TEST_DOMAIN } from '../../config/baseConfig';

describe('RN01 - Login com Sucesso', () => {
  // Dados de teste (usar prefixo qa_ obrigatoriamente)
  const testUser = {
    name: `${QA_PREFIX}usuario_login_001`,
    email: `${QA_PREFIX}usuario_login_001${TEST_DOMAIN}`,
    password: 'Senha@123456'
  };

  beforeEach(() => {
    // Antes de cada teste, navegar para a página de login
    cy.visit('/');
    
    // Limpar localStorage (remover tokens anteriores)
    cy.clearLocalStorage();
  });

  it('Deve fazer login com credenciais válidas', () => {
    // Arrange: Preparar dados (assumindo usuário já existe no banco)
    // Em um cenário real, você chamaria a API para criar o usuário ou mockaria a resposta

    // Act: Preenchimento do formulário e submissão
    cy.get('[data-testid="email-input"]')
      .should('be.visible')
      .type(testUser.email);
    
    cy.get('[data-testid="password-input"]')
      .should('be.visible')
      .type(testUser.password);
    
    cy.get('[data-testid="login-button"]')
      .should('be.visible')
      .and('not.be.disabled')
      .click();

    // Assert: Validações após login
    // 1. Redireciona para /home
    cy.url({ timeout: 10000 })
      .should('include', '/home');

    // 2. Token JWT é armazenado em localStorage
    cy.window()
      .then((win) => {
        const auth = win.localStorage.getItem('m3-bank-auth');
        expect(auth).to.exist;
        
        const parsed = JSON.parse(auth);
        expect(parsed).to.have.property('token');
        expect(parsed.token).to.be.a('string');
        
        // JWT deve ter 3 partes separadas por ponto: header.payload.signature
        expect(parsed.token.split('.')).to.have.length(3);
      });

    // 3. Nome do usuário é exibido no header
    cy.get('[data-testid="user-greeting"]')
      .should('be.visible')
      .and('contain', testUser.name);

    // 4. Botão "Sair" é exibido (indicando autenticação)
    cy.get('[data-testid="logout-button"]')
      .should('be.visible');

    // 5. Elementos protegidos são acessíveis
    cy.get('[data-testid="account-card"]')
      .should('be.visible');
  });

  it('Deve exibir erro com credenciais inválidas', () => {
    // Act: Tentar login com senha errada
    cy.get('[data-testid="email-input"]')
      .type(testUser.email);
    
    cy.get('[data-testid="password-input"]')
      .type('SenhaErrada123');
    
    cy.get('[data-testid="login-button"]')
      .click();

    // Assert: Erro é exibido
    cy.get('[data-testid="error-message"]')
      .should('be.visible')
      .and('contain', 'Credenciais inválidas');

    // URL permanece na página de login
    cy.url()
      .should('include', '/');

    // localStorage NÃO contém token
    cy.window()
      .then((win) => {
        const auth = win.localStorage.getItem('m3-bank-auth');
        expect(auth).to.not.exist;
      });
  });

  it('Deve exigir preenchimento de email e senha', () => {
    // Act: Clicar no botão sem preencher
    cy.get('[data-testid="login-button"]')
      .click();

    // Assert: Erro de validação é exibido
    cy.get('[data-testid="error-message"]')
      .should('be.visible')
      .and('contain', 'Usuário e senha precisam ser preenchidos');

    // URL permanece na página de login
    cy.url()
      .should('include', '/');
  });

  it('Deve desabilitar botão durante requisição', () => {
    // Act: Preencher e clicar
    cy.get('[data-testid="email-input"]')
      .type(testUser.email);
    
    cy.get('[data-testid="password-input"]')
      .type(testUser.password);
    
    const loginButton = cy.get('[data-testid="login-button"]');
    
    // Assert: Botão fica desabilitado
    loginButton
      .should('not.be.disabled')
      .click()
      .should('be.disabled')
      .and('contain', 'Carregando...');
  });

  afterEach(() => {
    // Após cada teste, limpar localStorage
    cy.clearLocalStorage();
  });
});

/**
 * Dicas de Escrita:
 * 
 * 1. Use data-testid para seletores (mais resilientes que classes CSS)
 *    ✅ cy.get('[data-testid="email-input"]')
 *    ❌ cy.get('.form-input')
 *    ❌ cy.get('input[type="email"]')
 * 
 * 2. Sempre use cy.should('be.visible') antes de interagir
 *    ✅ cy.get('[data-testid="button"]').should('be.visible').click()
 *    ❌ cy.get('[data-testid="button"]').click()
 * 
 * 3. Use timeout adequado para operações assincrónas
 *    ✅ cy.url({ timeout: 10000 })
 *    ❌ cy.url()
 * 
 * 4. Sempre comece com dados de teste usando prefixo qa_
 *    ✅ const name = 'qa_usuario_001'
 *    ❌ const name = 'usuario_001'
 * 
 * 5. Use comentários Arrange/Act/Assert
 *    ✅ // Arrange: dados // Act: ações // Assert: validações
